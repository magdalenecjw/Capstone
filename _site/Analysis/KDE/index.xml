background-color: null;
font-style: inherit;">adaptive.density</span>(pickup_owin, <span class="at" style="color: #657422;
background-color: null;
font-style: inherit;">method=</span><span class="st" style="color: #20794D;
background-color: null;
font-style: inherit;">"kernel"</span>)</span>
